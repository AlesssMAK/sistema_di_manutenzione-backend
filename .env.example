# --- Server ---
PORT=3040
NODE_ENV=development

# --- Database ---
MONGO_URL=mongodb://localhost:27017/sm

# --- Frontend (CORS, email links) ---
FRONTEND_URL=http://localhost:3000

# --- AdminJS panel ---
ADMIN_COOKIE_SECRET=
ADMIN_SESSION_SECRET=

# --- Email ---
# Driver: 'stub' (console.log) | 'smtp'
EMAIL_DRIVER=stub
EMAIL_FROM=noreply@mms.local
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# --- Cloudinary (fault images) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Socket.io ---
SOCKET_CORS_ORIGIN=http://localhost:3000

# --- Cron jobs ---
# Set to 'false' to disable cron (useful for tests)
CRON_ENABLED=true
